// FF Tournament - Prisma Schema
// Note: This SQLite schema mirrors the Firestore collections described in README.
// Collections: users, tournaments, registrations, paymentRequests, notifications, leaderboard, announcements, settings

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  uid           String   @unique // Firebase UID equivalent
  name          String
  email         String   @unique
  photoURL      String?
  role          String   @default("user") // "user" | "admin"
  registeredAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  registrations   Registration[]
  paymentRequests PaymentRequest[]
  notifications   Notification[]
  leaderboard     Leaderboard?
  prizeHistory    PrizeHistory[]
  wonTournaments  Tournament[] @relation("TournamentWinner")
}

model Tournament {
  id            String   @id @default(cuid())
  type          String // "1v1" | "2v2"
  title         String
  entryFee      Int // in INR
  prizeAmount   Int // in INR
  slotLimit     Int
  filledSlots   Int      @default(0)
  date          DateTime
  time          String
  roomId        String?
  roomPassword  String?
  roomPublished Boolean  @default(false)
  status        String   @default("active") // "active" | "completed" | "cancelled"
  rules         String
  winnerId      String?
  winner        User?    @relation("TournamentWinner", fields: [winnerId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  registrations Registration[]
  payments      PaymentRequest[]
  prizeHistory  PrizeHistory[]
}

model Registration {
  id           String   @id @default(cuid())
  userId       String
  tournamentId String
  status       String   @default("pending") // "pending" | "approved" | "rejected"
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  payment      PaymentRequest?

  @@unique([tournamentId, userId])
}

model PaymentRequest {
  id              String   @id @default(cuid())
  userId          String
  tournamentId    String
  registrationId  String   @unique
  screenshotURL   String // URL or base64 (mocked in sandbox)
  utrNumber       String
  amount          Int
  note            String?
  status          String   @default("pending") // "pending" | "approved" | "rejected"
  submittedAt     DateTime @default(now())
  reviewedAt      DateTime?

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament      Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  registration    Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String // "payment_approved" | "payment_rejected" | "tournament_registered" | "room_published" | "match_starting" | "tournament_completed"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Leaderboard {
  id           String  @id @default(cuid())
  userId       String  @unique
  matchesPlayed Int    @default(0)
  wins         Int     @default(0)
  prizeEarned  Int     @default(0)

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PrizeHistory {
  id            String   @id @default(cuid())
  userId        String
  tournamentId  String
  amount        Int
  createdAt     DateTime @default(now())

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model Announcement {
  id        String   @id @default(cuid())
  text      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Setting {
  id    String @id
  key   String @unique
  value String
}
